# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta WhatsApp API
WA_VERIFY_TOKEN=your-whatsapp-verify-token
WA_ACCESS_TOKEN=your-whatsapp-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_BUSINESS_ACCOUNT_ID=your-business-account-id

# Mercado Pago
MP_ACCESS_TOKEN=your-mp-access-token
MP_WEBHOOK_SECRET=your-mp-webhook-secret

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001